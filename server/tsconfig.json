{
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist",
        "module": "commonjs",
        "target": "es2020",
        "lib": [
            "es2020"
        ],
        "types": [
            "node"
        ],
        "sourceMap": true,
        "declaration": true,
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "prisma",
        "dist",
        "node_modules",
        "generated"
    ]
}